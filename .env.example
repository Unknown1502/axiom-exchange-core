# =============================================================================
# AXIOM environment configuration — copy to `.env` and fill in real values.
# `.env` is gitignored. NEVER commit real credentials.
# =============================================================================

# -----------------------------------------------------------------------------
# Local development — PostgreSQL 16 in Docker (emulates Aurora DSQL's
# REPEATABLE READ + optimistic-concurrency behavior, including SQLSTATE 40001).
# This is what `npm run db:up && npm run db:migrate && npm test` uses.
# -----------------------------------------------------------------------------
# Port 55432 avoids colliding with any native PostgreSQL on the default 5432.
DATABASE_URL=postgresql://axiom:axiom_local_dev@localhost:55432/axiom

# Set to "require" against Aurora DSQL; "disable" for the local Docker container.
DATABASE_SSL=disable

# -----------------------------------------------------------------------------
# Aurora DSQL (production) — set after you provision the cluster
# (`npm run provision:aws` creates it and prints the endpoint).
# DSQL authenticates with a short-lived IAM token used as the Postgres password,
# generated at connection time (see docs/operations/deploy.md).
# Setting DSQL_CLUSTER_ENDPOINT (or DATABASE_TARGET=dsql) switches the migration
# runner to DSQL dialect (CREATE INDEX ASYNC, one DDL per transaction).
# -----------------------------------------------------------------------------
# DSQL_CLUSTER_ENDPOINT=<cluster-id>.dsql.<region>.on.aws
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Aurora DSQL MULTI-REGION (the "one ledger across Regions" demo).
# Provision with `npm run provision:aws:multiregion` — it creates two peered
# clusters + a witness Region and prints these values. Then run
# `npm run db:migrate:dsql:multiregion`, set MULTIREGION=1, and start the API.
# Tear everything down afterwards with `npm run teardown:aws:multiregion`.
# -----------------------------------------------------------------------------
# MULTIREGION=1
# DSQL_ENDPOINT_US=<id>.dsql.us-east-1.on.aws
# DSQL_REGION_US=us-east-1
# DSQL_ENDPOINT_EU=<id>.dsql.us-east-2.on.aws
# DSQL_REGION_EU=us-east-2
# DSQL_WITNESS_REGION=us-west-2
# Identifiers (needed only for teardown):
# DSQL_IDENTIFIER_US=<id>
# DSQL_IDENTIFIER_EU=<id>

# -----------------------------------------------------------------------------
# DynamoDB — order-event firehose (audit log).
# Local dev uses DynamoDB Local in Docker (npm run db:up starts it on :8000).
# Leave DYNAMODB_ENDPOINT unset in production to use the real AWS endpoint.
# -----------------------------------------------------------------------------
AWS_REGION=us-east-1
DYNAMODB_TABLE_NAME=order_events
DYNAMODB_ENDPOINT=http://localhost:8000

# Production (real AWS) — set credentials via the default provider chain and
# UNSET DYNAMODB_ENDPOINT:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# -----------------------------------------------------------------------------
# Intake API + demo
# -----------------------------------------------------------------------------
INTAKE_PORT=3001
DEMO_SYMBOL=BTC-USD
DEMO_REGION=us
