{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noImplicitAny": true,
    "noUncheckedIndexedAccess": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "types": ["node"],
    "paths": {
      "@axiom/shared-types": ["./packages/shared-types/src/index.ts"],
      "@axiom/database": ["./packages/database/src/index.ts"],
      "@axiom/matching-engine": ["./packages/matching-engine/src/index.ts"],
      "@axiom/dynamodb-client": ["./packages/dynamodb-client/src/index.ts"]
    }
  },
  "include": ["packages/**/*.ts", "tests/**/*.ts", "scripts/**/*.ts"],
  "exclude": ["node_modules", "**/dist"]
}
